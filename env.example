# Copy to .env and fill in values. Never commit .env.

# MongoDB Atlas (use your connection string; add a database name in the path or set MONGODB_DB_NAME)
MONGODB_URI=
MONGODB_DB_NAME=component_compass

# Auth (use a long random string in production)
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Optional: AI advisor & reports (set at least one)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LOVABLE_API_KEY=
