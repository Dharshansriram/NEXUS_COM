{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "checkJs": false,
    "noEmit": true,
    "types": ["vite/client"]
  },
  "include": [
    "src/**/*.js",
    "src/**/*.jsx",
    "vite.config.mjs",
    "vitest.config.mjs",
    "tailwind.config.mjs"
  ]
}
